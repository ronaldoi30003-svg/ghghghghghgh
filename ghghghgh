local originalWaist, originalNeck
local waist, neck

local function cacheCharacter(char)
    task.wait(0.2)

    waist, neck = getJoints(char)

    if waist then
        originalWaist = waist.C0
    end

    if neck then
        originalNeck = neck.C0
    end
