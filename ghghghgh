lp.CharacterAdded:Connect(cacheCharacter)

local function isFirstPerson()
    local char = lp.Character
    local cam = workspace.CurrentCamera
    if not char or not cam then return false end

    local head = char:FindFirstChild("Head")
    if not head then return false end

    return (cam.CFrame.Position - head.Position).Magnitude < 1.3
end

RunService.RenderStepped:Connect(function()
    if not AntiAimEnabled then return end
    if isFirstPerson() then return end

    local char = lp.Character
    if not char or not waist or not neck then return end
    if not originalWaist or not originalNeck then return end

    local angle = 0

    if AntiAimMode == "Up" then
        angle = math.rad(-60)

    elseif AntiAimMode == "Down" then
        angle = math.rad(60)

    elseif AntiAimMode == "Jitter" then
        jitter = not jitter
        angle = jitter and math.rad(-60) or math.rad(60)
    else
        return
    end

    waist.C0 = originalWaist * CFrame.Angles(angle, 0, 0)
    neck.C0 = originalNeck * CFrame.Angles(angle * 0.5, 0, 0)
end)

